# ============================================================
#  BankAssistant — Variables d'environnement
#  1. Copier ce fichier : cp .env.example .env
#  2. Remplir ENCRYPTION_KEY et SECRET_KEY (voir commandes ci-dessous)
#  IMPORTANT : ne jamais committer .env dans git !
# ============================================================

# --- Base de données ---
DB_PATH=/app/data/bankassistant.db

# Clé de chiffrement Fernet (chiffre les identifiants CA et clés API en base)
# Générer avec :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGER_MOI_cle_fernet_32_octets_base64

# --- Sécurité JWT ---
# Clé secrète pour signer les tokens JWT (min 32 caractères aléatoires)
# Générer avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGER_MOI_cle_secrete_jwt_tres_longue_et_aleatoire

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Verrouillage du compte après N tentatives échouées
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# --- Woob / Crédit Agricole ---
# Répertoire de données woob (modules bancaires)
WOOB_DATA_DIR=/app/woob-data

# --- Intelligence Artificielle ---
# Provider par défaut : groq | mistral | ollama
# (configurable depuis l'IHM sans redémarrage)
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# Clé API Groq — gratuit sur https://console.groq.com
# (peut aussi être saisie depuis l'IHM → Paramètres → IA)
GROQ_API_KEY=

# Clé API Mistral — tier "Experiment" gratuit sur https://console.mistral.ai
MISTRAL_API_KEY=

# URL Ollama si déployé localement (ex: http://host.docker.internal:11434)
OLLAMA_BASE_URL=

# --- Notifications push (ntfy auto-hébergé) ---
# URL interne du service ntfy (dans le réseau Docker)
NTFY_URL=http://ntfy:80
# Topic ntfy — doit correspondre à ce que vous abonnez dans l'app Android
NTFY_TOPIC=bankassistant
# Token d'accès ntfy (optionnel, si auth activée dans ntfy)
NTFY_TOKEN=

# --- Application ---
# URL publique de l'application (utilisée pour CORS et les liens dans les notifications)
# En local : https://localhost ou http://localhost:8080
APP_URL=https://localhost
LOG_LEVEL=INFO
# Mettre à true pour activer /docs et /redoc (désactiver en production)
DEBUG=false

# ============================================================
#  BankAssistant — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
#  IMPORTANT : ne jamais committer .env dans git !
# ============================================================

# --- Base de données ---
DB_PATH=/app/data/bankassistant.db

# Clé de chiffrement Fernet (32 octets base64-url)
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGER_MOI_cle_fernet_32_octets_base64

# --- Sécurité JWT ---
# Clé secrète aléatoire forte (min 32 caractères)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGER_MOI_cle_secrete_jwt_tres_longue_et_aleatoire

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Tentatives de connexion avant verrouillage
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# --- Woob / Crédit Agricole ---
WOOB_DATA_DIR=/app/woob-data

# --- IA ---
# Provider par défaut : groq | mistral | ollama
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# Clé API Groq (gratuit sur console.groq.com)
GROQ_API_KEY=

# Clé API Mistral (gratuit tier experiment sur console.mistral.ai)
MISTRAL_API_KEY=

# URL Ollama (si activé, ex: http://host.docker.internal:11434)
OLLAMA_BASE_URL=

# --- Notifications ntfy ---
NTFY_URL=http://ntfy:80
NTFY_TOPIC=bankassistant
# Token d'accès ntfy (configuré dans ntfy si auth activée)
NTFY_TOKEN=

# --- Application ---
APP_URL=https://localhost
LOG_LEVEL=INFO
DEBUG=false
